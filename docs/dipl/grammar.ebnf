(* ===================================================== *)
(* DIPL 1.0 Minimal Grammar                             *)
(* Reference Implementation Grammar                     *)
(* ===================================================== *)

document
= { line } ;

line
= statement newline
| newline ;

statement
= source_decl
| node_decl
| node_update
| conditional
;

(* ----------------------------------------------------- *)
(* Sources                                               *)
(* ----------------------------------------------------- *)

source_decl
= "$source" identifier "=" string ;

(* ----------------------------------------------------- *)
(* Nodes                                                 *)
(* ----------------------------------------------------- *)

node_decl
= identifier
type_spec
[ array_spec ]
"="
expression
[ unit_spec ] ;

node_update
= identifier
"="
expression
[ unit_spec ] ;

(* ----------------------------------------------------- *)
(* Types                                                 *)
(* ----------------------------------------------------- *)

type_spec
= "bool"
| "int"
| "float"
| "str"
| "table" ;

(* ----------------------------------------------------- *)
(* Arrays                                                *)
(* ----------------------------------------------------- *)

array_spec
= "["
integer
{ "," integer }
"]" ;

array
= "["
[ expression { "," expression } ]
"]" ;

(* ----------------------------------------------------- *)
(* Units                                                 *)
(* ----------------------------------------------------- *)

unit_spec
= identifier
{ ( "*" | "/" ) identifier } ;

(* ----------------------------------------------------- *)
(* References                                            *)
(* ----------------------------------------------------- *)

reference
= "{"
reference_path
"}" ;

reference_path
= "?"
| "?" identifier
| identifier "?" identifier
| identifier
;

(* ----------------------------------------------------- *)
(* Expressions                                           *)
(* ----------------------------------------------------- *)

expression
= logical_or ;

logical_or
= logical_and
{ "||" logical_and } ;

logical_and
= equality
{ "&&" equality } ;

equality
= comparison
{ ( "==" | "!=" ) comparison } ;

comparison
= additive
{ ( "<" | "<=" | ">" | ">=" ) additive } ;

additive
= multiplicative
{ ( "+" | "-" ) multiplicative } ;

multiplicative
= unary
{ ( "*" | "/" ) unary } ;

unary
= [ "-" | "!" ]
primary ;

primary
= literal
| array
| reference
| function_call
| "(" expression ")" ;

(* ----------------------------------------------------- *)
(* Functions                                             *)
(* ----------------------------------------------------- *)

function_call
= identifier
"("
[ argument_list ]
")" ;

argument_list
= expression
{ "," expression } ;

(* ----------------------------------------------------- *)
(* Conditionals                                          *)
(* ----------------------------------------------------- *)

conditional
= if_stmt
| elif_stmt
| else_stmt
| end_stmt ;

if_stmt
= "@if"
"(" expression ")" ;

elif_stmt
= "@elif"
"(" expression ")" ;

else_stmt
= "@else" ;

end_stmt
= "@end" ;

(* ----------------------------------------------------- *)
(* Literals                                              *)
(* ----------------------------------------------------- *)

literal
= boolean
| integer
| float
| string
| "none" ;

boolean
= "true"
| "false" ;

(* ----------------------------------------------------- *)
(* Lexer Rules                                           *)
(* ----------------------------------------------------- *)

identifier
= letter
{ letter | digit | "_" } ;

integer
= digit
{ digit } ;

float
= integer "." integer ;

string
= '"' { character } '"' ;

letter
= "A"…"Z"
| "a"…"z" ;

digit
= "0"…"9" ;

newline
= "\n" ;

(* ========================= *)
(*        LEXICAL RULES      *)
(* ========================= *)

letter        = "A"…"Z" | "a"…"z" | "_" ;
digit         = "0"…"9" ;
identifier    = letter , { letter | digit } ;

path_char     = ? any character except whitespace and '=' ? ;
path          = path_char , { path_char } ;

whitespace    = " " | "\t" ;
newline       = "\n" | "\r\n" ;

(* ========================= *)
(*        DOCUMENT           *)
(* ========================= *)

document      = { statement } ;

statement     = source_definition
              | node_definition
              | newline ;

(* ========================= *)
(*     SOURCE DEFINITION     *)
(* ========================= *)

source_definition =
    "$source" , whitespace , identifier , whitespace , "=" , whitespace , path ;

(* ========================= *)
(*      NODE DEFINITION      *)
(* ========================= *)

node_definition =
    identifier , ":" , { node_property } ;

node_property =
    whitespace , property ;

property      =
    value_property
  | condition_property
  | reference_property ;

(* ========================= *)
(*        PROPERTIES         *)
(* ========================= *)

value_property =
    "value" , ":" , whitespace , expression ;

condition_property =
    "!condition" , whitespace , "(" , expression , ")" ;

reference_property =
    "ref" , ":" , whitespace , reference ;

(* ========================= *)
(*        REFERENCES         *)
(* ========================= *)

reference =
    "{" , reference_body , "}" ;

reference_body =
      self_reference
    | local_reference
    | remote_reference
    | source_only ;

(* --- self reference --- *)
self_reference =
    "?" ;

(* --- local reference --- *)
local_reference =
    "?" , query ;

(* --- remote reference --- *)
remote_reference =
    identifier , "?" , [ query ] ;

(* --- full source content --- *)
source_only =
    identifier ;

(* ========================= *)
(*           QUERY           *)
(* ========================= *)

query =
    path_segment , { "." , path_segment } , [ wildcard ] ;

path_segment =
    identifier ;

wildcard =
    "." , "*" ;

(* ========================= *)
(*        EXPRESSIONS        *)
(* ========================= *)

expression =
    term , { operator , term } ;

term =
      number
    | reference
    | identifier
    | "(" , expression , ")" ;

operator =
      "+"
    | "-"
    | "*"
    | "/"
    | "<"
    | ">"
    | "<="
    | ">="
    | "=="
    | "!=" ;

number =
    digit , { digit } , [ "." , digit , { digit } ] ;

(* ========================= *)
(*        SEMANTICS NOTES    *)
(* ========================= *)

(*

1. { ? } is only valid inside condition_property.
2. { ? query } refers to local domain.
3. { source ? query } refers to remote domain.
4. { source } returns full source content.
5. Missing source implies local domain.
6. Query wildcard ".*" selects child nodes (semantics defined elsewhere).

*)